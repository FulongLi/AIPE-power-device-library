{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aipe.local/schemas/device.schema.json",
  "title": "AIPE DeviceRecord",
  "type": "object",
  "required": [
    "id",
    "manufacturer",
    "part_number",
    "technology",
    "device_class",
    "package",
    "ratings",
    "sources"
  ],
  "properties": {
    "id": { "type": "string" },
    "manufacturer": { "type": "string" },
    "part_number": { "type": "string" },
    "technology": { "enum": ["Si", "SiC", "GaN"] },
    "device_class": {
      "enum": ["mosfet", "jfet", "hemt", "igbt", "diode", "module"]
    },
    "description": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "package": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "mounting": { "type": "string" },
        "pins": {
          "type": "array",
          "items": { "type": "string" }
        },
        "isolation_voltage": { "$ref": "#/$defs/quantity" },
        "parasitic_inductance": { "$ref": "#/$defs/quantity" }
      }
    },
    "ratings": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/quantity" }
    },
    "electrical": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/quantity" }
    },
    "thermal": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/quantity" }
    },
    "gan": {
      "type": "object",
      "properties": {
        "structure": {
          "enum": ["e_mode", "p_gan", "cascode", "d_mode", "unknown"]
        },
        "dynamic_rds_on_factor": { "$ref": "#/$defs/quantity" },
        "vgs_abs_max": { "$ref": "#/$defs/quantity" },
        "reverse_conduction_voltage": { "$ref": "#/$defs/quantity" },
        "has_body_diode": { "type": "boolean" }
      }
    },
    "module": {
      "type": "object",
      "properties": {
        "topology": {
          "enum": [
            "half_bridge",
            "full_bridge",
            "six_pack",
            "boost",
            "buck",
            "three_level",
            "custom"
          ]
        },
        "die_count": { "$ref": "#/$defs/quantity" },
        "switch_positions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "thermal_paths": {
          "type": "array",
          "items": { "type": "object" }
        },
        "has_ntc": { "type": "boolean" }
      }
    },
    "curves": {
      "type": "array",
      "items": { "$ref": "#/$defs/curve" }
    },
    "raw_data_packages": {
      "type": "array",
      "items": { "$ref": "#/$defs/rawDataPackage" }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    }
  },
  "$defs": {
    "quantity": {
      "type": "object",
      "required": ["value", "unit", "source_id"],
      "properties": {
        "value": { "type": "number" },
        "unit": { "type": "string" },
        "condition": {
          "type": "object",
          "additionalProperties": true
        },
        "source_id": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "source": {
      "type": "object",
      "required": ["id", "type", "title"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "enum": [
            "datasheet",
            "application_note",
            "characterization_report",
            "raw_test_data",
            "measurement",
            "simulation",
            "estimate"
          ]
        },
        "category": {
          "enum": [
            "manufacturer_document",
            "manufacturer_model",
            "third_party_characterization",
            "internal_measurement",
            "simulation",
            "estimate"
          ]
        },
        "subtype": {
          "enum": [
            "datasheet_table",
            "datasheet_curve_digitized",
            "application_note",
            "spice_model",
            "plecs_model",
            "double_pulse_test",
            "curve_tracer",
            "thermal_transient",
            "gate_charge_test",
            "capacitance_test",
            "reverse_recovery_test",
            "raw_waveform",
            "post_processed_dataset",
            "manual_estimate"
          ]
        },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "revision": { "type": "string" },
        "date": { "type": "string" },
        "lab": { "type": "string" },
        "traceability": {
          "type": "object",
          "additionalProperties": true
        },
        "notes": { "type": "string" }
      }
    },
    "rawDataPackage": {
      "type": "object",
      "required": ["id", "source_id", "test_type"],
      "properties": {
        "id": { "type": "string" },
        "source_id": { "type": "string" },
        "test_type": { "type": "string" },
        "operator": { "type": "string" },
        "test_date": { "type": "string" },
        "equipment": {
          "type": "array",
          "items": { "type": "object" }
        },
        "setup": {
          "type": "object",
          "additionalProperties": true
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "kind": { "type": "string" },
              "path": { "type": "string" },
              "format": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "curve": {
      "type": "object",
      "required": ["id", "type", "source_id", "x", "y", "points"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "enum": [
            "iv_output",
            "iv_transfer",
            "capacitance",
            "switching_energy",
            "gate_charge",
            "soa",
            "thermal_impedance",
            "on_resistance_vs_temperature",
            "vce_sat_vs_temperature",
            "reverse_recovery"
          ]
        },
        "source_id": { "type": "string" },
        "condition": {
          "type": "object",
          "additionalProperties": true
        },
        "x": { "$ref": "#/$defs/axis" },
        "y": { "$ref": "#/$defs/axis" },
        "points": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "array",
            "prefixItems": [{ "type": "number" }, { "type": "number" }],
            "minItems": 2,
            "maxItems": 2
          }
        },
        "digitization": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "axis": {
      "type": "object",
      "required": ["label", "unit"],
      "properties": {
        "label": { "type": "string" },
        "unit": { "type": "string" }
      }
    }
  }
}
